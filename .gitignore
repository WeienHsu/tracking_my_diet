# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
pic/
*.png

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Obsidian 筆記連結（指向本機 vault 的絕對路徑，不可進 git）
/kanban_task

# Python 虛擬環境
/.venv

# AI 工具的個人指示檔（指向 repo 外的 ../CLAUDE.md，上傳會變壞掉的連結）
/CLAUDE.md
/AGENTS.md
/GEMINI.md

# macOS
.DS_Store

# 個人開發計劃 / 筆記，不上傳
/PROJECT_PLAN.md

# 改進計劃文件（給人看的計劃），不上傳
/docs/
